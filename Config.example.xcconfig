// Example configuration file for Moblin
// Copy this to Config.xcconfig and customize for your setup

// Example 1: Personal developer
BUNDLE_ID_PREFIX = com.myname.Moblin
BUNDLE_ID_PREFIX_REVERSED = Moblin.myname.com
DEVELOPMENT_TEAM = ABC123DEF4
CODE_SIGN_STYLE = Automatic

